{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "ChangLi",
  "version": "0.8.9",
  "identifier": "com.changli.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "长离",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; media-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/mpv/**/*"
    ],
    "windows": {
      "allowDowngrades": false,
      "nsis": {
        "template": "nsis/installer.nsi",
        "headerImage": "nsis/installer-header.bmp",
        "sidebarImage": "nsis/installer-sidebar.bmp",
        "installerIcon": "icons/icon.ico",
        "languages": [
          "SimpChinese"
        ],
        "displayLanguageSelector": false,
        "installMode": "both"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "mpv",
          "cmd": "mpv",
          "args": true
        }
      ]
    },
    "fs": {
      "scope": {
        "allow": ["**"]
      }
    },
    "http": {
      "scope": [
        "http://**",
        "https://**"
      ]
    }
  }
}
