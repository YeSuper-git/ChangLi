{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "ChangLi",
  "version": "1.9.0",
  "identifier": "com.changli.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.github.com https://github.com; img-src 'self' asset: https://asset.localhost data:; media-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/nip/**/*",
      "resources/mpv/**/*",
      "resources/ffmpeg/**/*",
      "resources/webview2/**/*",
      "lib/*"
    ],
    "windows": {
      "allowDowngrades": false,
      "nsis": {
        "headerImage": "nsis/installer-header.bmp",
        "sidebarImage": "nsis/installer-sidebar.bmp",
        "installerIcon": "icons/icon.ico",
        "languages": [
          "SimpChinese"
        ],
        "displayLanguageSelector": false,
        "installMode": "both"
      },
      "manifest": {
        "assembly": {
          "identity": {
            "name": "ChangLi",
            "version": "1.9.0"
          },
          "description": "ChangLi Video Manager",
          "compatibility": {
            "supportedOS": [
              "{8e0f7a12-bfb3-4fe8-b9a5-48fd50a15a9a}",
              "{1f676c76-80e1-4239-95bb-83d0f6d0da78}",
              "{35138b9a-5d96-4fbd-8e2d-a2440225f93a}"
            ]
          }
        }
      }
    }
  }
}